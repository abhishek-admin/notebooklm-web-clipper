{
  "manifest_version": 3,
  "name": "NotebookLM Web Clipper",
  "description": "One-click clip any web page to NotebookLM — Gemini previews the page, NotebookLM opens with the source auto-added.",
  "version": "2.0.0",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "32": "icons/icons32.png"
    }
  },
  "icons": {
    "32": "icons/icons32.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": ["*://notebooklm.google.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    },
    {
      "matches": ["*://notebooklm.google.com/*"],
      "js": ["notebooklm-injector.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://openrouter.ai/*",
    "https://notebooklm.google.com/*"
  ]
}
